# Copy this to .env.production (never commit real values)
# Set each of these as Production environment variables in the Vercel dashboard.

# Anthropic API key — required for the AI concierge
ANTHROPIC_API_KEY=

# Enables mock crowd simulation (no Firebase needed for demo)
NEXT_PUBLIC_MOCK_MODE=true

# Set to your Vercel deployment URL after first deploy
# e.g. https://stadiumiq.vercel.app
NEXT_PUBLIC_BASE_URL=https://stadiumiq.vercel.app
